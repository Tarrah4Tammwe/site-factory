# Site Factory Environment Variables
# Copy this to .env.local and fill in your values

# Authentication - choose a strong random string, only you need to know this
FACTORY_PASSWORD=your-secret-password-here

# Anthropic API - get from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GitHub - generate a PAT at https://github.com/settings/tokens
# Needs: repo (full), workflow
GITHUB_TOKEN=your-github-token-here
GITHUB_USERNAME=Tarrah4Tammwe

# Google Custom Search - get from https://programmablesearchengine.google.com
# Free: 100 queries/day
GOOGLE_SEARCH_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

